@media (max-width: 480px) {
    /*menu*/
    .header__menu-ico {
        display: block;
    }
    .header__menu {
        display: none;
        flex-direction: column;
        gap: 10%;
        background: #fff;
    }
    .header__checkbox:checked ~ .header__menu {
        display: flex;
    }
    /*REMOVI ANINHAMNETO*/
    .header__menu-link {
    display: block;
    padding: 15px 20px;
    border: 2px solid black;
    box-sizing: border-box;
    }

    /*secao servicos*/
    .servicos {
    grid-template-columns: 1fr;
    grid-template-rows: repeat(5, auto);
